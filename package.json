{
  "name": "voskify",
  "version": "0.0.1",
  "description": "A Node.js wrapper for Vosk via koffi.",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "author": "sinber",
  "license": "MIT",
  "files": [
    "src",
    "vosk-lib/**/*.dll",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "vosk",
    "wavefile",
    "koffi",
    "asr",
    "speech-recognition",
    "speech-to-text",
    "offline"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SinbereeGit/Voskify.git"
  },
  "homepage": "https://github.com/SinbereeGit/Voskify",
  "bugs": {
    "url": "https://github.com/SinbereeGit/Voskify/issues"
  },
  "scripts": {
    "test": "mocha",
    "test:exclude-slow": "mocha --ignore \"test/**/*.slow.spec.{mjs,js,cjs}\"",
    "zip": "bestzip zips/voskify.zip src/* vosk-lib package.json package-lock.json",
    "changeset": "changeset",
    "release:prepare": "changeset version"
  },
  "dependencies": {
    "koffi": "^2.16.1",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "bestzip": "^2.2.3",
    "chai": "^6.2.2",
    "mocha": "^11.7.5"
  }
}
